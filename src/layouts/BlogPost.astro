---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { Image } from "astro:assets";

type Props = CollectionEntry<"blog">["data"] & { journalFooter?: boolean };

const { title, description, pubDate, updatedDate, heroImage, journalFooter = false } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <!-- Google Analytics Script -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-0M58B909ZC"
    ></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-0M58B909ZC");
    </script>
    <!-- End Google Analytics Script -->
    <style>
      main {
        width: calc(100% - 2em);
        max-width: 100%;
        margin: 0;
      }
      .hero-image {
        width: 100%;
      }
      .hero-image img {
        display: block;
        margin: 0 auto;
        border-radius: 12px;
        box-shadow: var(--box-shadow);
      }
      .prose {
        width: 720px;
        max-width: calc(100% - 2em);
        margin: auto;
        padding: 1em;
        color: rgb(var(--gray-dark));
      }
      .title {
        border-bottom: 1px solid rgb(var(--gray-light));
        margin: 0 0 2.25rem;
        padding: 1.5rem 0 1.75rem;
      }
      .title h1 {
        font-size: clamp(2rem, 4.5vw, 2.9rem);
        letter-spacing: -0.035em;
        line-height: 1.08;
        margin: 0;
        text-wrap: balance;
      }
      .meta {
        color: rgb(var(--gray));
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        margin-bottom: 0.8rem;
        text-transform: uppercase;
      }
      .last-updated-on {
        color: rgb(var(--gray));
        font-size: 0.92rem;
        font-style: italic;
        margin-top: 0.7rem;
      }
      .post-footer {
        border-top: 1px solid rgb(var(--gray-light));
        color: rgb(var(--gray));
        font-size: 0.95rem;
        line-height: 1.6;
        margin-top: 3.5rem;
        padding-top: 1.4rem;
      }
      .post-footer .back {
        display: inline-block;
        font-weight: 700;
        margin-bottom: 0.6rem;
        text-decoration: none;
      }
      .post-footer .back:hover {
        text-decoration: underline;
      }
      .post-footer p {
        margin: 0;
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <article>
        <div class="hero-image">
          {
            heroImage && (
              <Image
                width={1020}
                height={510}
                src={heroImage}
                alt=""
                loading="lazy"
              />
            )
          }
        </div>
        <div class="prose">
          <div class="title">
            <div class="meta">
              <FormattedDate date={pubDate} />
            </div>
            <h1>{title}</h1>
            {
              updatedDate && (
                <div class="last-updated-on">
                  Last updated on <FormattedDate date={updatedDate} />
                </div>
              )
            }
          </div>
          <slot />
          {
            journalFooter && (
              <footer class="post-footer">
                <a class="back" href="/blog/">
                  ← Back to the journal
                </a>
                <p>
                  Questions or corrections: <a href="mailto:benjamin.m.brannen@gmail.com">benjamin.m.brannen@gmail.com</a>.
                </p>
              </footer>
            )
          }
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>

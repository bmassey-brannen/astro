---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = posts[0];
const rest = posts.slice(1);

const byYear = new Map<number, typeof posts>();
for (const post of rest) {
  const year = post.data.pubDate.getFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(post);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Journal | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-0M58B909ZC"
    ></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-0M58B909ZC");
    </script>
    <style>
      main {
        max-width: 1080px;
        padding: 0 1.25rem 4rem;
        width: 100%;
      }

      .archive-hero {
        margin: 2rem 0 1.5rem;
        max-width: 820px;
      }

      .eyebrow {
        color: var(--accent);
        font-size: 0.82rem;
        font-weight: 900;
        letter-spacing: 0.14em;
        margin-bottom: 0.75rem;
        text-transform: uppercase;
      }

      .archive-hero h1 {
        font-size: clamp(2.4rem, 5vw, 4.25rem);
        letter-spacing: -0.05em;
        line-height: 0.96;
        margin-bottom: 1rem;
      }

      .archive-hero p {
        color: rgb(var(--gray-dark));
        font-size: 1.12rem;
        line-height: 1.6;
        max-width: 720px;
      }

      .feature-card,
      .post-card {
        background: rgba(255, 255, 255, 0.78);
        border: 1px solid rgba(var(--gray), 0.16);
        border-radius: 24px;
        box-shadow: 0 12px 30px rgba(var(--gray), 0.12);
        overflow: hidden;
      }

      .feature-card {
        display: grid;
        grid-template-columns: minmax(280px, 0.95fr) minmax(0, 1.05fr);
        margin: 1.75rem 0 2rem;
      }

      .feature-card img,
      .post-card img {
        background: #0f171b;
        display: block;
        width: 100%;
      }

      .feature-card img {
        height: 100%;
        object-fit: contain;
      }

      .feature-content,
      .post-content {
        padding: 1.15rem;
      }

      .feature-content {
        align-self: center;
        padding: 1.5rem;
      }

      .feature-content h2 {
        font-size: clamp(1.7rem, 3vw, 2.35rem);
        letter-spacing: -0.035em;
        margin: 0.3rem 0 0.75rem;
      }

      .date {
        color: rgb(var(--gray));
        font-size: 0.9rem;
        font-weight: 800;
      }

      .feature-card a,
      .entry a {
        color: inherit;
        text-decoration: none;
      }

      .button {
        align-items: center;
        background: rgba(55, 80, 92, 0.08);
        border: 1px solid rgba(55, 80, 92, 0.18);
        border-radius: 999px;
        color: var(--accent-dark);
        display: inline-flex;
        font-weight: 800;
        line-height: 1;
        margin-top: 0.35rem;
        padding: 0.8rem 1rem;
        text-decoration: none;
      }

      .year-group {
        margin: 2.5rem 0 0;
      }

      .year-group h2 {
        align-items: baseline;
        color: rgb(var(--gray));
        display: flex;
        font-size: 1rem;
        font-weight: 900;
        gap: 1rem;
        letter-spacing: 0.12em;
        margin: 0 0 0.35rem;
      }

      .year-group h2::after {
        background: rgba(var(--gray), 0.25);
        content: "";
        flex: 1;
        height: 1px;
      }

      .entry-list {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .entry {
        border-bottom: 1px solid rgba(var(--gray), 0.16);
      }

      .entry a {
        display: grid;
        gap: 0.2rem 1.5rem;
        grid-template-columns: 7.25rem minmax(0, 1fr);
        padding: 1.05rem 0.25rem;
      }

      .entry a:hover h3 {
        color: var(--accent-dark);
        text-decoration: underline;
      }

      .entry .date {
        padding-top: 0.22rem;
      }

      .entry h3 {
        font-size: 1.22rem;
        letter-spacing: -0.02em;
        line-height: 1.25;
        margin: 0;
      }

      .entry p {
        color: rgb(var(--gray));
        font-size: 0.96rem;
        grid-column: 2;
        line-height: 1.55;
        margin: 0.25rem 0 0;
      }

      .archive-note {
        background: rgba(255, 248, 223, 0.78);
        border: 1px solid rgba(55, 80, 92, 0.16);
        border-radius: 22px;
        color: rgb(var(--gray-dark));
        margin: 2rem 0;
        padding: 1.1rem 1.25rem;
      }

      @media (max-width: 860px) {
        .feature-card {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 640px) {
        .entry a {
          grid-template-columns: 1fr;
          padding-inline: 0;
        }

        .entry .date {
          padding-top: 0;
        }

        .entry p {
          grid-column: 1;
        }
      }

      @media (max-width: 560px) {
        main {
          padding-inline: 0.85rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="archive-hero">
        <p class="eyebrow">Operator journal</p>
        <h1>Build logs, research notes, and field reports.</h1>
        <p>
          This is the public layer of the work: what I am learning while building
          dashboards, research systems, local intelligence workflows, and Small
          Town Capital. Enough of the process to be useful. Not enough to turn
          the private playbook into a giveaway.
        </p>
      </section>

      {
        featured && (
          <article class="feature-card">
            <a href={`/blog/${featured.slug}/`}>
              {featured.data.heroImage && (
                <img src={featured.data.heroImage} alt={featured.data.title} loading="eager" />
              )}
            </a>
            <div class="feature-content">
              <div class="date"><FormattedDate date={featured.data.pubDate} /></div>
              <h2><a href={`/blog/${featured.slug}/`}>{featured.data.title}</a></h2>
              <p>{featured.data.description}</p>
              <a class="button" href={`/blog/${featured.slug}/`}>Read the latest</a>
            </div>
          </article>
        )
      }

      <p class="archive-note">
        Note: public posts are receipts and reflections. They are not trade alerts,
        execution instructions, or a map of the private research system.
      </p>

      {
        years.map((year) => (
          <section class="year-group" aria-label={`Posts from ${year}`}>
            <h2>{year}</h2>
            <ul class="entry-list">
              {byYear.get(year)!.map((post) => (
                <li class="entry">
                  <a href={`/blog/${post.slug}/`}>
                    <span class="date">
                      <FormattedDate date={post.data.pubDate} />
                    </span>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </main>
    <Footer />
  </body>
</html>

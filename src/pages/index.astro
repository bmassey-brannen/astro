---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import FormattedDate from "../components/FormattedDate.astro";

const posts = await getCollection("blog");

const sortedPosts = posts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate);
  const dateB = new Date(b.data.pubDate);
  return dateB.getTime() - dateA.getTime();
});

const featuredPost = sortedPosts[0];
const recentPosts = sortedPosts.slice(1, 4);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-0M58B909ZC"
    ></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-0M58B909ZC");
    </script>
    <style>
      main {
        max-width: 1080px;
        padding: 0 1.25rem 4rem;
        width: 100%;
      }

      .hero {
        display: grid;
        gap: 1.2rem;
        grid-template-columns: minmax(0, 1.15fr) minmax(300px, 0.85fr);
        align-items: start;
        margin: 1.65rem auto 2.15rem;
      }

      .eyebrow {
        color: var(--accent);
        font-size: 0.82rem;
        font-weight: 900;
        letter-spacing: 0.14em;
        margin-bottom: 0.85rem;
        text-transform: uppercase;
      }

      .hero h1 {
        font-size: clamp(2.35rem, 5.1vw, 3.95rem);
        letter-spacing: -0.045em;
        line-height: 1;
        margin-bottom: 1rem;
        max-width: 680px;
        text-wrap: balance;
      }

      .hero-lede {
        color: rgb(var(--gray-dark));
        font-size: clamp(1.04rem, 1.8vw, 1.2rem);
        line-height: 1.55;
        max-width: 680px;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        margin-top: 1.25rem;
      }

      .button {
        align-items: center;
        border-radius: 999px;
        display: inline-flex;
        font-weight: 800;
        line-height: 1;
        padding: 0.85rem 1.1rem;
        text-decoration: none;
      }

      .button.primary {
        background: var(--accent);
        color: white;
      }

      .button.secondary {
        background: rgba(55, 80, 92, 0.08);
        border: 1px solid rgba(55, 80, 92, 0.18);
        color: var(--accent-dark);
      }

      .portrait-card {
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid rgba(var(--gray), 0.18);
        border-radius: 24px;
        box-shadow: 0 12px 30px rgba(var(--gray), 0.16);
        margin: 0;
        overflow: hidden;
        max-width: 340px;
        justify-self: end;
      }

      .portrait-card img {
        aspect-ratio: 1 / 1;
        display: block;
        object-fit: cover;
        width: 100%;
      }

      .portrait-card figcaption {
        color: rgb(var(--gray));
        font-size: 0.9rem;
        line-height: 1.45;
        padding: 0.85rem 1rem 1rem;
      }

      .section-heading {
        align-items: end;
        display: flex;
        gap: 1rem;
        justify-content: space-between;
        margin: 2.35rem 0 1rem;
      }

      .section-heading h2 {
        margin: 0;
      }

      .section-heading a {
        font-weight: 800;
      }

      .focus-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .focus-card,
      .feature-card,
      .post-card {
        background: rgba(255, 255, 255, 0.75);
        border: 1px solid rgba(var(--gray), 0.16);
        border-radius: 22px;
        box-shadow: 0 10px 28px rgba(var(--gray), 0.12);
      }

      .focus-card {
        padding: 1.15rem;
      }

      .focus-card h3 {
        font-size: 1.25rem;
        margin-top: 0;
      }

      .focus-card p {
        color: rgb(var(--gray-dark));
        font-size: 0.98rem;
        line-height: 1.55;
        margin-bottom: 0;
      }

      .proof-strip {
        background: linear-gradient(135deg, rgba(55, 80, 92, 0.12), rgba(31, 93, 66, 0.12));
        border: 1px solid rgba(55, 80, 92, 0.18);
        border-radius: 24px;
        margin: 2.35rem 0;
        padding: 1.15rem 1.25rem;
      }

      .proof-strip p {
        font-size: 1.08rem;
        line-height: 1.65;
        margin: 0;
      }

      .desk-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: 1.1fr 0.9fr;
        margin: 2.35rem 0;
      }

      .desk-panel {
        background: #111b20;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 24px;
        box-shadow: 0 18px 45px rgba(17, 27, 32, 0.22);
        color: #edf3ed;
        padding: 1.35rem;
      }

      .desk-panel h2,
      .desk-panel h3 {
        color: #fff8df;
      }

      .desk-panel h2 {
        font-size: clamp(1.6rem, 3vw, 2.15rem);
        margin-top: 0;
      }

      .desk-panel p {
        color: rgba(237, 243, 237, 0.82);
        line-height: 1.6;
      }

      .desk-list {
        display: grid;
        gap: 0.8rem;
        list-style: none;
        margin: 1rem 0 0;
        padding: 0;
      }

      .desk-list li {
        border-top: 1px solid rgba(255, 255, 255, 0.12);
        padding-top: 0.8rem;
      }

      .desk-list strong {
        color: #fff8df;
        display: block;
        margin-bottom: 0.15rem;
      }

      .private-note {
        background: rgba(255, 248, 223, 0.78);
        border: 1px solid rgba(55, 80, 92, 0.16);
        border-radius: 24px;
        box-shadow: 0 10px 28px rgba(var(--gray), 0.1);
        padding: 1.35rem;
      }

      .private-note h3 {
        margin-top: 0;
      }

      .private-note p {
        color: rgb(var(--gray-dark));
        line-height: 1.58;
      }

      .feature-card {
        display: grid;
        gap: 1.25rem;
        grid-template-columns: minmax(240px, 0.9fr) minmax(0, 1.1fr);
        overflow: hidden;
      }

      .feature-card img,
      .post-card img {
        display: block;
        width: 100%;
      }

      .feature-card img {
        aspect-ratio: 16 / 9;
        background: #0c1118;
        height: 100%;
        object-fit: contain;
      }

      .feature-content {
        padding: 1.25rem 1.25rem 1.25rem 0;
      }

      .feature-content h3 {
        font-size: clamp(1.55rem, 3vw, 2.15rem);
        margin-top: 0.4rem;
      }

      .date {
        color: rgb(var(--gray));
        font-size: 0.9rem;
        font-weight: 700;
      }

      .post-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .post-card {
        overflow: hidden;
      }

      .post-card img {
        aspect-ratio: 16 / 9;
        background: #f4f1dc;
        height: auto;
        object-fit: cover;
      }

      .post-card-content {
        padding: 1rem;
      }

      .post-card h3 {
        font-size: 1.15rem;
        margin: 0.35rem 0 0.65rem;
      }

      .post-card a,
      .feature-card a {
        color: inherit;
        text-decoration: none;
      }

      .post-card a:hover,
      .feature-card a:hover {
        color: var(--accent-dark);
      }

      .mini-note {
        color: rgb(var(--gray));
        font-size: 0.95rem;
      }

      @media (max-width: 860px) {
        .hero,
        .feature-card,
        .focus-grid,
        .desk-grid,
        .post-grid {
          grid-template-columns: 1fr;
        }

        .feature-content {
          padding: 0 1.15rem 1.2rem;
        }

        .portrait-card {
          justify-self: stretch;
          max-width: none;
        }

        .portrait-card img {
          aspect-ratio: 16 / 10;
        }
      }

      @media (max-width: 560px) {
        main {
          padding-inline: 0.85rem;
        }

        .eyebrow {
          font-size: 0.68rem;
          letter-spacing: 0.16em;
          margin-bottom: 0.55rem;
        }

        .hero h1 {
          font-size: clamp(1.95rem, 9vw, 2.55rem);
          margin-bottom: 0.75rem;
        }

        .hero-lede {
          font-size: 0.96rem;
          line-height: 1.5;
        }

        .hero-actions {
          gap: 0.55rem;
          margin-top: 0.95rem;
        }

        .button {
          font-size: 0.92rem;
          padding: 0.72rem 0.9rem;
        }

        .section-heading {
          align-items: start;
          flex-direction: column;
        }

        .hero {
          gap: 1rem;
          margin-top: 0.85rem;
        }

        .portrait-card {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <Header title={SITE_TITLE} />
    <main>
      <section class="hero">
        <div>
          <p class="eyebrow">Small Town Capital · Operator Journal</p>
          <h1>The garage-built intelligence desk.</h1>
          <p class="hero-lede">
            I write about the work behind Small Town Capital: dashboards, public
            records, market structure, local capital, and the little tools that
            make messy systems easier to see. No guru act. No magic signals.
            Just the notebook, the receipts, and the parts I can show without
            giving away the playbook.
          </p>
          <div class="hero-actions">
            <a class="button primary" href="/blog/">Read the journal</a>
            <a class="button secondary" href="/about/">About Ben</a>
          </div>
        </div>

        <figure class="portrait-card">
          <img src="/bmbrun.jpg" alt="Ben Brannen running" />
          <figcaption>
            Runner, builder, dashboard tinkerer, and operator behind Small Town
            Capital.
          </figcaption>
        </figure>
      </section>

      <section aria-labelledby="focus-heading">
        <div class="section-heading">
          <h2 id="focus-heading">What this site is about</h2>
        </div>
        <div class="focus-grid">
          <article class="focus-card">
            <h3>Build logs</h3>
            <p>
              Notes from building dashboards, trading tools, automations, and
              research systems that make scattered information easier to act on.
            </p>
          </article>
          <article class="focus-card">
            <h3>Market structure</h3>
            <p>
              Notes on options architecture, LEAPs, short-call handcuffs,
              decision logs, and the discipline of not strangling a good trade
              because I got impatient.
            </p>
          </article>
          <article class="focus-card">
            <h3>Public records</h3>
            <p>
              Research habits from following entities, incentives, filings,
              meeting minutes, property records, and the paperwork trail.
            </p>
          </article>
        </div>
      </section>

      <section class="proof-strip" aria-label="Operating loop">
        <p>
          The loop is <strong>research → structure → publish → build → invest → learn → repeat.</strong>
          This site is the public notebook for that loop. Enough proof to show
          the work. Not so much detail that the playbook becomes a giveaway.
        </p>
      </section>

      <section class="desk-grid" aria-labelledby="desk-heading">
        <div class="desk-panel">
          <p class="eyebrow">Current desk</p>
          <h2 id="desk-heading">What needs to survive my mood</h2>
          <p>
            The private work is becoming a research terminal, market desk, source
            tracker, and decision journal. The whole point is to keep the thesis
            intact when emotion gets loud. The public work proves the reps are
            happening.
          </p>
          <ul class="desk-list">
            <li>
              <strong>Research before reaction</strong>
              Source-backed notes, not screenshots pretending to be a thesis.
            </li>
            <li>
              <strong>Structure before exposure</strong>
              Defined-risk thinking, patience, and fewer ways to cap the thing I was right about.
            </li>
            <li>
              <strong>Receipts before reputation</strong>
              Build logs and visible learning before any grand claim.
            </li>
          </ul>
        </div>
        <aside class="private-note">
          <h3>What stays off the site</h3>
          <p>
            I am not publishing live trade instructions, private scanner rules,
            account details, or anything that turns research into a copy-trade
            circus. The public layer should make the work legible without leaking
            the edge.
          </p>
          <p>
            If a post sounds more like a field note than a sales page, good.
            This is an operator journal, not a funnel wearing a tweed jacket.
          </p>
        </aside>
      </section>

      {
        featuredPost && (
          <section aria-labelledby="featured-heading">
            <div class="section-heading">
              <h2 id="featured-heading">Featured latest</h2>
              <a href="/blog/">All posts →</a>
            </div>
            <article class="feature-card">
              <a href={`/blog/${featuredPost.slug}/`}>
                {featuredPost.data.heroImage && (
                  <img
                    src={featuredPost.data.heroImage}
                    alt={featuredPost.data.title}
                    loading="eager"
                  />
                )}
              </a>
              <div class="feature-content">
                <div class="date">
                  <FormattedDate date={featuredPost.data.pubDate} />
                </div>
                <h3>
                  <a href={`/blog/${featuredPost.slug}/`}>
                    {featuredPost.data.title}
                  </a>
                </h3>
                <p>{featuredPost.data.description}</p>
                <a class="button secondary" href={`/blog/${featuredPost.slug}/`}>
                  Read the post
                </a>
              </div>
            </article>
          </section>
        )
      }

      <section aria-labelledby="recent-heading">
        <div class="section-heading">
          <h2 id="recent-heading">Recent field notes</h2>
          <a href="/blog/">Browse the archive →</a>
        </div>
        <div class="post-grid">
          {
            recentPosts.map((post) => (
              <article class="post-card">
                <a href={`/blog/${post.slug}/`}>
                  {post.data.heroImage && (
                    <img
                      src={post.data.heroImage}
                      alt={post.data.title}
                      loading="eager"
                    />
                  )}
                </a>
                <div class="post-card-content">
                  <div class="date">
                    <FormattedDate date={post.data.pubDate} />
                  </div>
                  <h3>
                    <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                  </h3>
                  <p class="mini-note">{post.data.description}</p>
                </div>
              </article>
            ))
          }
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
